---
import BottomSection from "@/components/BottomSection.astro";
import Hero from "@/components/Hero.astro";
import Timeline from "@/components/Timeline.astro";
import Layout from "@/layouts/Layout.astro";


---

<Layout>
  <Hero />
  <Timeline />
  <BottomSection />
</Layout>
<script>
  const chineseTimeZones = new Set([
    "Asia/Shanghai",
    "Asia/Hong_Kong",
    "Asia/Macau",
    "Asia/Taipei",
  ]);

  const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone;
  let preferredLocale = null;

  try {
    preferredLocale = localStorage.getItem("clawd.locale");
  } catch {
    preferredLocale = null;
  }

  if (!preferredLocale && timeZone && chineseTimeZones.has(timeZone)) {
    window.location.replace("/zh/");
  }
</script>
