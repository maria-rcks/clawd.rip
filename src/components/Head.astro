---
import "../styles/global.css";
import { timelineEvents } from "@/data/timeline";
import { zhTimelineEvents } from "@/data/timeline.zh";

type Locale = "en" | "zh";

const { locale = "en" } = Astro.props as { locale?: Locale };
const isZh = locale === "zh";
const localizedTimelineEvents = isZh ? zhTimelineEvents : timelineEvents;
const siteTitle = isZh
  ? "Claude 翻车全记录"
  : "Everything That Went Wrong With Claude";
const siteDescription = isZh
  ? "一条带点讽刺的中文时间线，记录 Claude 和 Anthropic 的争议、宕机、封禁、法律纠纷、政策冲突与质量投诉。"
  : "A satirical timeline of Claude and Anthropic controversies, outages, bans, legal disputes, policy fights, and quality complaints.";
const siteUrl = Astro.site ?? new URL("https://clawd.rip");
const pageUrl = new URL(isZh ? "/zh/" : "/", siteUrl);
const previewImage = new URL("/og-image.png", siteUrl);
const imageAlt = isZh
  ? "Clawd.rip 中文页面：Claude 翻车全记录。"
  : "Clawd.rip hero: Everything that went wrong with Claude.";
const timelineSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: siteTitle,
  description: siteDescription,
  url: pageUrl.toString(),
  numberOfItems: localizedTimelineEvents.length,
  itemListElement: localizedTimelineEvents.map((event, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: new URL(`#event-${index + 1}`, pageUrl).toString(),
    item: {
      "@type": "Article",
      headline: event.title,
      description: event.summary,
      datePublished: event.date,
      articleSection: event.category,
      mainEntityOfPage: new URL(`#event-${index + 1}`, pageUrl).toString(),
      citation: event.sources.map((source) => source.url),
    },
  })),
};
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={siteDescription} />
  <meta name="theme-color" content="#faf9f5" />
  <link rel="canonical" href={pageUrl.toString()} />
  <link rel="alternate" hreflang="en" href={new URL("/", siteUrl).toString()} />
  <link rel="alternate" hreflang="zh-CN" href={new URL("/zh/", siteUrl).toString()} />
  <link rel="alternate" hreflang="x-default" href={new URL("/", siteUrl).toString()} />
  <link rel="icon" href="/brand/claude-ai-icon.svg" type="image/svg+xml" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={pageUrl.toString()} />
  <meta property="og:site_name" content="Clawd.rip" />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={siteDescription} />
  <meta property="og:image" content={previewImage.toString()} />
  <meta
    property="og:image:alt"
    content={imageAlt}
  />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={siteDescription} />
  <meta name="twitter:image" content={previewImage.toString()} />
  <meta
    name="twitter:image:alt"
    content={imageAlt}
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(timelineSchema)}
  />
  <title>{siteTitle}</title>
</head>
