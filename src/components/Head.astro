---
import "../styles/global.css";
import { timelineEvents } from "@/data/timeline";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  imageAlt?: string;
  ogType?: string;
  schema?: Record<string, unknown>;
}

const siteTitle = "Everything That Went Wrong With Claude";
const siteDescription =
  "A satirical timeline of Claude and Anthropic controversies, outages, bans, legal disputes, policy fights, and quality complaints.";
const siteUrl = Astro.site ?? new URL("https://clawd.rip");

const title = Astro.props.title ?? siteTitle;
const description = Astro.props.description ?? siteDescription;
const pageUrl = new URL(Astro.props.path ?? "/", siteUrl);
const previewImage = new URL(Astro.props.image ?? "/og-image.png", siteUrl);
const previewImageAlt =
  Astro.props.imageAlt ?? "Clawd.rip hero: Everything that went wrong with Claude.";
const ogType = Astro.props.ogType ?? "website";

const timelineSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: siteTitle,
  description: siteDescription,
  url: siteUrl.toString(),
  numberOfItems: timelineEvents.length,
  itemListElement: timelineEvents.map((event, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: new URL(`/events/${event.slug}/`, siteUrl).toString(),
    item: {
      "@type": "Article",
      headline: event.title,
      description: event.summary,
      datePublished: event.date,
      articleSection: event.category,
      mainEntityOfPage: new URL(`/events/${event.slug}/`, siteUrl).toString(),
      citation: event.sources.map((source) => source.url),
    },
  })),
};

const schema = Astro.props.schema ?? timelineSchema;
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#faf9f5" />
  <link rel="canonical" href={pageUrl.toString()} />
  <link rel="icon" href="/brand/claude-ai-icon.svg" type="image/svg+xml" />

  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={pageUrl.toString()} />
  <meta property="og:site_name" content="Clawd.rip" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={previewImage.toString()} />
  <meta property="og:image:alt" content={previewImageAlt} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={previewImage.toString()} />
  <meta name="twitter:image:alt" content={previewImageAlt} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
  <script is:inline>
    try {
      if (localStorage.getItem("clawd-theme") === "dark") {
        document.documentElement.classList.add("dark");
        var themeMeta = document.querySelector('meta[name="theme-color"]');
        if (themeMeta) themeMeta.setAttribute("content", "#1f1d19");
      }
    } catch {
      /* localStorage unavailable */
    }
  </script>
  <title>{title}</title>
</head>
