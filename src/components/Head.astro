---
import "../styles/global.css";
import { timelineEvents } from "@/data/timeline";

const siteTitle = "Everything That Went Wrong With Claude";
const siteDescription =
  "A satirical timeline of Claude and Anthropic controversies, outages, bans, legal disputes, policy fights, and quality complaints.";
const siteUrl = Astro.site ?? new URL("https://clawd.rip");
const previewImage = new URL("/og-image.png", siteUrl);
const timelineSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: siteTitle,
  description: siteDescription,
  url: siteUrl.toString(),
  numberOfItems: timelineEvents.length,
  itemListElement: timelineEvents.map((event, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: new URL(`#event-${index + 1}`, siteUrl).toString(),
    item: {
      "@type": "Article",
      headline: event.title,
      description: event.summary,
      datePublished: event.date,
      articleSection: event.category,
      mainEntityOfPage: new URL(`#event-${index + 1}`, siteUrl).toString(),
      citation: event.sources.map((source) => source.url),
    },
  })),
};
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={siteDescription} />
  <meta name="theme-color" content="#faf9f5" />
  <link rel="canonical" href={siteUrl.toString()} />
  <link rel="icon" href="/brand/claude-ai-icon.svg" type="image/svg+xml" />
  <link
    rel="shortcut icon"
    href="/brand/claude-ai-icon.svg"
    type="image/svg+xml"
  />
  <link rel="apple-touch-icon" href="/brand/claude-ai-icon.svg" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl.toString()} />
  <meta property="og:site_name" content="Clawd.rip" />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={siteDescription} />
  <meta property="og:image" content={previewImage.toString()} />
  <meta
    property="og:image:alt"
    content="Clawd.rip hero: Everything that went wrong with Claude."
  />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={siteDescription} />
  <meta name="twitter:image" content={previewImage.toString()} />
  <meta
    name="twitter:image:alt"
    content="Clawd.rip hero: Everything that went wrong with Claude."
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(timelineSchema)}
  />
  <title>{siteTitle}</title>
</head>
