---

---

<section class="hero-section relative bg-(--canvas)">
  <div
    class="hero-shell mx-auto w-full max-w-352 px-6 py-3 sm:px-10 sm:py-4 lg:px-20"
  >
    <div class="hero-lockup">
      <div class="hero-copy min-w-0">
        <h1 class="brand-title leading-[0.95] text-(--ink)">
          <span class="hero-line-one block">
            Everything that <span class="hero-correction">
              <span class="hero-struck">went</span>
              <span class="hero-insert">is</span>
            </span>
          </span>
          <span class="block">wrong with Claude.</span>
        </h1>
      </div>
      <img
        src="/brand/claude-pixelart.png"
        alt=""
        class="hero-pixel-art"
        width="28"
        height="11"
        loading="eager"
        decoding="async"
        aria-hidden="true"
      />
    </div>
  </div>
</section>
