---
import "../styles/global.css";
import { timelineEvents } from "@/data/timeline";
import { categoryStyles, getIncidentLayers } from "@/lib/event-visuals";

const displayedTimelineEvents = [...timelineEvents].reverse();
---

<section class="relative bg-(--surface)">
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-linear-to-b from-(--canvas) to-(--surface) sm:h-28 lg:h-32"
    aria-hidden="true"
  >
  </div>
  <div
    class="relative mx-auto w-full max-w-352 overflow-hidden px-6 pb-6 pt-0 sm:px-10 sm:pb-8 lg:px-20"
  >
    <div
      class="timeline-toolbar relative z-20 mb-5 flex justify-start md:justify-center"
    >
      <button
        id="timeline-order-toggle"
        type="button"
        class="timeline-order-button ui-text"
        data-order="newest"
      >
        Oldest first
      </button>
    </div>
    <div class="relative">
      <div
        class="timeline-spine absolute bottom-0 left-2.75 top-4.25 md:left-1/2 md:-translate-x-1/2"
        aria-hidden="true"
      >
      </div>
      <ol id="timeline" class="relative">
        {
          displayedTimelineEvents.map((event, index) => {
            const layers = getIncidentLayers(event.category, index);

            return (
              <li
                id={`event-${timelineEvents.length - index}`}
                data-category={event.category}
                data-timeline-entry
                class="timeline-entry relative pb-16 pl-10 md:pl-0"
              >
                <svg
                  class="timeline-marker absolute left-[0.4rem] top-2.25 z-10 h-4 w-4 md:left-1/2 md:-translate-x-1/2"
                  viewBox="0 0 16 16"
                  aria-hidden="true"
                >
                  <circle cx="8" cy="8" r="8"></circle>
                  <path d="M3.4 3.9 Q8 7.3 12.8 12.4"></path>
                  <path d="M12.5 3.4 Q8.2 7.9 3.6 12.7"></path>
                </svg>
                <figure class="timeline-visual" aria-hidden="true">
                  {layers.map((layer, layerIndex) => (
                    <img
                      src={layer}
                      alt=""
                      class="incident-layer"
                      style={`--layer-index: ${layerIndex}`}
                      width="512"
                      height="512"
                      loading="lazy"
                    />
                  ))}
                </figure>
                <article class="timeline-content relative">
                  <svg
                    class="timeline-marker-mobile absolute -left-9.25 top-[0.53125rem] z-10 h-4 w-4 md:hidden"
                    viewBox="0 0 16 16"
                    aria-hidden="true"
                  >
                    <circle cx="8" cy="8" r="8"></circle>
                    <path d="M3.4 3.9 Q8 7.3 12.8 12.4"></path>
                    <path d="M12.5 3.4 Q8.2 7.9 3.6 12.7"></path>
                  </svg>
                  <div
                    class="timeline-branch absolute -left-8 top-[1.03125rem] w-8"
                    aria-hidden="true"
                  ></div>
                  <div class="timeline-meta">
                    <time
                      datetime={event.date}
                      class="timeline-meta-date ui-text block text-sm font-semibold leading-6 text-(--muted)"
                    >
                      {event.period}
                    </time>
                    <span
                      class={`timeline-meta-category ui-text inline-flex items-center rounded-full border px-2.5 py-px text-sm font-medium leading-4 ${categoryStyles[event.category]}`}
                    >
                      {event.category}
                    </span>
                  </div>
                  <h2 class="timeline-title mt-4 text-[1.7rem] text-balance font-medium leading-[1.14] text-(--ink) md:text-[1.8rem]">
                    <a
                      href={`/events/${event.slug}/`}
                      class="timeline-title-link transition hover:text-(--accent-dark)"
                    >
                      {event.title}
                    </a>
                  </h2>
                  <p class="mt-4 text-base leading-7 text-balance text-(--ink-soft)">
                    {event.summary}
                  </p>
                  <p class="mt-3">
                    <a
                      href={`/events/${event.slug}/`}
                      class="ui-text text-sm font-medium text-[color-mix(in_srgb,var(--accent-dark)_70%,transparent)] underline decoration-1 underline-offset-[0.2em] transition hover:text-(--accent-dark)"
                    >
                      Full story
                    </a>
                  </p>
                  <div class="timeline-sources mt-5 flex flex-wrap gap-2">
                    {event.sources.map((source) => (
                      <a
                        href={source.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="ui-text inline-flex max-w-full items-center gap-1.5 rounded-[3px] border border-(--line) bg-(--canvas) px-2.5 py-1 text-sm leading-5 text-(--ink-soft) transition hover:border-(--ink) hover:text-(--ink)"
                      >
                        <img
                          src={source.icon}
                          alt=""
                          class="h-3.5 w-3.5 shrink-0"
                          width="14"
                          height="14"
                          loading="lazy"
                          aria-hidden="true"
                        />
                        <span class="truncate">{source.title}</span>
                        <span class="sr-only">opens in a new tab</span>
                      </a>
                    ))}
                  </div>
                </article>
              </li>
            );
          })
        }
      </ol>
    </div>
  </div>
</section>
<script>
  const timeline = document.querySelector("#timeline");
  const orderToggle = document.querySelector("#timeline-order-toggle");
  const observedEntries = document.querySelectorAll(".timeline-entry");
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;
  const timelineEntries = timeline
    ? Array.from(timeline.querySelectorAll("[data-timeline-entry]")).filter(
        (entry) => entry instanceof HTMLElement,
      )
    : [];

  const setTimelineOrder = (order: "oldest" | "newest") => {
    if (!timeline || !orderToggle) {
      return;
    }

    const isNewest = order === "newest";
    const orderedEntries = isNewest
      ? timelineEntries
      : [...timelineEntries].reverse();

    for (const entry of orderedEntries) {
      timeline.append(entry);
    }

    orderToggle.setAttribute("data-order", order);
    orderToggle.textContent = isNewest ? "Oldest first" : "Newest first";
  };

  if (timeline && orderToggle) {
    setTimelineOrder("newest");

    orderToggle.addEventListener("click", () => {
      setTimelineOrder(
        orderToggle.getAttribute("data-order") === "newest"
          ? "oldest"
          : "newest",
      );
    });
  }

  if (prefersReducedMotion || !("IntersectionObserver" in window)) {
    for (const entry of observedEntries) {
      entry.classList.add("is-visible");
    }
  } else {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          entry.target.classList.toggle("is-visible", entry.isIntersecting);
        }
      },
      { rootMargin: "-18% 0px -18% 0px", threshold: 0.2 },
    );

    for (const entry of observedEntries) {
      revealObserver.observe(entry);
    }
  }
</script>
