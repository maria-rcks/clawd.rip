---
type Locale = "en" | "zh";

const { locale = "en" } = Astro.props as { locale?: Locale };
const isZh = locale === "zh";
const nextLocale = isZh ? "en" : "zh";
const localeHref = isZh ? "/" : "/zh/";
const localeLabel = isZh ? "English" : "中文";
const localeAriaLabel = isZh ? "Switch to English" : "切换到中文";
---

<header class="site-header">
  <div class="header-inner mx-auto flex max-w-352 items-center justify-between">
    <a
      href="/"
      class="brand-link flex items-center"
      aria-label={isZh ? "Clawd.rip 首页" : "Clawd.rip home"}
    >
      <img
        src="/brand/claude-ai-icon.svg"
        alt=""
        class="brand-icon"
        width="256"
        height="257"
        aria-hidden="true"
      />
      <img
        src="/brand/clawd-rip-text-cropped.avif"
        alt="Clawd.rip"
        class="brand-wordmark"
        width="936"
        height="225"
      />
    </a>
    <div class="header-actions flex min-w-0 items-center gap-3">
      <p
        class="ui-text affiliate-note inline-flex min-w-0 items-center gap-2 text-(--muted)"
      >
        <span
          class="affiliate-note-label text-[0.7rem] font-bold uppercase leading-none tracking-[0.08em] opacity-80"
        >
          {isZh ? "非官方关联" : "Not affiliated with"}
        </span>
        <img
          src="/brand/anthropic-wordmark.svg"
          alt="Anthropic"
          class="h-2.5 w-auto opacity-70"
          width="182"
          height="24"
        />
      </p>
      <a
        href={localeHref}
        class="language-toggle ui-text"
        data-locale-switch={nextLocale}
        aria-label={localeAriaLabel}
      >
        {localeLabel}
      </a>
    </div>
  </div>
</header>
<script>
  for (const link of document.querySelectorAll("[data-locale-switch]")) {
    link.addEventListener("click", () => {
      if (!(link instanceof HTMLElement)) {
        return;
      }

      const locale = link.dataset.localeSwitch;

      if (!locale) {
        return;
      }

      try {
        localStorage.setItem("clawd.locale", locale);
      } catch {
        // Navigation still works if storage is unavailable.
      }
    });
  }
</script>
