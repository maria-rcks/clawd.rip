---

---

<header class="site-header">
  <div class="header-inner mx-auto flex max-w-352 items-center justify-between">
    <a
      href="/"
      class="brand-link flex items-center"
      aria-label="Clawd.rip home"
    >
      <img
        src="/brand/claude-ai-icon.svg"
        alt=""
        class="brand-icon"
        width="256"
        height="257"
        aria-hidden="true"
      />
      <img
        src="/brand/clawd-rip-text-cropped.avif"
        alt="Clawd.rip"
        class="brand-wordmark"
        width="936"
        height="225"
      />
    </a>
    <p
      class="ui-text affiliate-note inline-flex min-w-0 items-center gap-2 text-(--muted)"
    >
      <span
        class="affiliate-note-label text-[0.7rem] font-bold uppercase leading-none tracking-[0.08em] opacity-80"
      >
        Not affiliated with
      </span>
      <img
        src="/brand/anthropic-wordmark.svg"
        alt="Anthropic"
        class="h-2.5 w-auto opacity-70"
        width="182"
        height="24"
      />
    </p>
  </div>
</header>
